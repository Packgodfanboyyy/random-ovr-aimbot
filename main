local modelId = 108924116694361
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local root = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Root")

local counter = 0
local lastTime = tick()
local spamRate = 25

-- Scale factor (1.5 = 50% bigger, change this if you want more/less)
local scaleFactor = 1.6

-- Test load
local success, model = pcall(function()
    local objects = game:GetObjects("rbxassetid://" .. modelId)
    return objects[1]
end)

if success and model then
    model.Parent = workspace
    local pos = root.Position + Vector3.new(0, 5, 0)
    
    if model.PrimaryPart then
        model:SetPrimaryPartCFrame(CFrame.new(pos))
    else
        model:MoveTo(pos)
    end
    
    -- Scale the test model too
    model:ScaleTo(scaleFactor)
end

-- Spammer
RunService.RenderStepped:Connect(function()
    local now = tick()
    if now - lastTime >= 1 / spamRate then
        pcall(function()
            local objects = game:GetObjects("rbxassetid://" .. modelId)
            local clone = objects[1]:Clone()
            if clone then
                clone.Parent = workspace
                
                local offset = Vector3.new(math.random(-4,4), math.random(2,6), math.random(-4,4))
                local pos = root.Position + offset
                
                if clone.PrimaryPart then
                    clone:SetPrimaryPartCFrame(CFrame.new(pos))
                elseif clone:FindFirstChild("HumanoidRootPart") or clone:FindFirstChild("Root") then
                    local yes = clone:FindFirstChild("HumanoidRootPart") or clone:FindFirstChild("Root")
                    yes.CFrame = CFrame.new(pos)
                else
                    clone:MoveTo(pos)
                end
                
                -- Make it bigger
                clone:ScaleTo(scaleFactor)
                
                Debris:AddItem(clone, 5)
                counter = counter + 1
            end
        end)
        lastTime = now
    end
end)
